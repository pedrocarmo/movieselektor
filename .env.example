# Copy to .env and fill in. The app works without any of these set.
# Get a free TMDB key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
OVERSEERR_URL=        # e.g. https://seerr.example.com

# Signal integration via bbernhard/signal-cli-rest-api.
# All three must be set for the "Share to Signal" button to appear.
SIGNAL_API_URL=       # e.g. http://signal-api:8080
SIGNAL_SENDER_NUMBER= # your number in E.164 format, e.g. +351xxxxxxxxx
SIGNAL_GROUP_ID=      # Signal group ID
